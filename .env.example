# Database path (relative to current working directory)
# In Docker: /app/data/novelapp.db
# In development: ./dev.db
DB_PATH=./dev.db

# Disable browser-based scraping on headless servers (true/false)
# Set to true in Docker to gracefully fail on protected sites
# Protected sites can still be scraped from local dev machine
DISABLE_BROWSER_SCRAPING=false

# Server port
PORT=3000

// Docker Image docker pull mghee/novelapp:latest
