# Example environment variables for NovelApp
# Copy this file to `.env.local` and fill values. Do NOT commit secrets.

# Secret used by server, extension and Android app for bearer auth and to sign
# the session cookie. Must be a long random string (40+ chars).
AUTH_SECRET=replace-with-very-long-random-string

# Server-side cookie lifetime (seconds). Default: 7 days
AUTH_SESSION_MAX_AGE_SECONDS=604800

# Restrict CORS for API requests. In production set to your app origin
# (e.g. https://novelapp.viktorbarzin.me). If empty or unset, '*' is used.
ALLOWED_ORIGIN=https://novelapp.viktorbarzin.me
# To also allow the browser extension or other origins, add them comma-separated.
# Examples:
# ALLOWED_ORIGIN=https://novelapp.viktorbarzin.me,chrome-extension://<EXTENSION_ID>
# ALLOWED_ORIGIN=https://novelapp.viktorbarzin.me,https://other.example.com
# Example with your extension ID (pack the extension with your private key to keep
# a stable ID):
# ALLOWED_ORIGIN=https://novelapp.viktorbarzin.me,chrome-extension://iimkcdnbmfdfcpmhdiioboijpofgjifo

# Path to SQLite DB file used by Prisma (optional). Defaults to ./dev.db
DB_PATH=./dev.db

# Disable headless browser scraping (useful in CI or restricted envs)
# Set to 'true' to disable Puppeteer scraping.
DISABLE_BROWSER_SCRAPING=false

# Optional runtime tuning (used by standalone server build)
#PORT=3000
#HOSTNAME=0.0.0.0
#KEEP_ALIVE_TIMEOUT=0
