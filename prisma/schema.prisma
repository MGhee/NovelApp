generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DB_PATH")
}

model User {
  id        String     @id
  email     String     @unique
  name      String?
  picture   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  books     Book[]
  apiTokens ApiToken[]
}

model ApiToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique
  label      String    @default("Default")
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}

model Book {
  id                Int           @id @default(autoincrement())
  title             String
  author            String?
  coverUrl          String?
  description       String?
  genre             String?
  status            Status        @default(PLAN_TO_READ)
  type              BookType      @default(WEB_NOVEL)
  siteUrl           String?
  currentChapter    Int           @default(0)
  currentChapterUrl String?
  totalChapters     Int           @default(0)
  isFavorite        Boolean       @default(false)
  yearRead          Int?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  userId            String?
  user              User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters        Character[]
  customFields      CustomField[]
  chapters          Chapter[]

  @@unique([userId, siteUrl])
}

model Chapter {
  id     Int     @id @default(autoincrement())
  number Int
  title  String?
  url    String
  bookId Int
  book   Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model Character {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  role        String?
  bookId      Int
  book        Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

model CustomField {
  id     Int    @id @default(autoincrement())
  key    String
  value  String
  bookId Int
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
}

enum Status {
  READING
  COMPLETED
  PLAN_TO_READ
  DROPPED
}

enum BookType {
  WEB_NOVEL
  LIGHT_NOVEL
  MANGA
  MANHWA
  PDF_DOWNLOAD
}
